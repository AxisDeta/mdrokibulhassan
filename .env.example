# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
# For Development (SQLite) - Leave MySQL settings empty or commented out
DATABASE_URL=sqlite:///portfolio.db

# For Production (MySQL) - Uncomment and fill these in
# DB_HOST=your-mysql-host.com
# DB_USER=your-mysql-username
# DB_PASSWORD=your-mysql-password
# DB_NAME=your-database-name
# DB_PORT=3306

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Optional: Production Database (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost/portfolio_db
